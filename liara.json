{
  "app": "backend-cheatsgame-staging",
  "platform": "django",
  "port": 7000,
  "build": {
    "location": "germany"
  },
  "django": {
    "pythonVersion": "3.9"
  },
  "healthCheck": {
    "command": [
      "CMD",
      "curl",
      "--fail",
      "--silent",
      "--show-error",
      "--header",
      "X-Forwarded-Proto:https",
      "--header",
      "Host:backend-cheatsgame-staging.liara.run",
      "http://127.0.0.1:8000/health/ready/"
    ],
    "interval": 30000,
    "timeout": 10000,
    "retries": 3,
    "startPeriod": 3000
  }
}
